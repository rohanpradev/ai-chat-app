{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"lib": ["ESNext"],
		"module": "ESNext",
		"moduleDetection": "force",
		"moduleResolution": "bundler",
		"noEmit": true,
		"noUncheckedSideEffectImports": true,
		"types": ["node"],
		"verbatimModuleSyntax": true
	},
	"extends": "../tsconfig.json",
	"include": ["./**/*.ts"]
}
