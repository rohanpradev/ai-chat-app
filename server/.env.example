# Server environment variables template
# Copy this file to .env.docker and update ALL values below
# All values are REQUIRED unless marked as optional

# Server configuration
SERVER_PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Database configuration - ALL REQUIRED
DB_PASSWORD=your_db_password_here
DB_USER=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=chatapp
DB_URL=postgres://postgres:your_db_password_here@db:5432/chatapp

# Redis configuration - REQUIRED
REDIS_URL=redis://:redis_password@redis:6379

# OpenAI - REQUIRED for AI features
OPENAI_API_KEY=your_openai_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# Langfuse - OPTIONAL for AI observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# JWT configuration - REQUIRED (Generate a secure 32+ character string)
JWT_SECRET=your_jwt_secret_32_chars_minimum_here

# Client URL for CORS - REQUIRED
CLIENT_URL=http://localhost

# API configuration - REQUIRED
BASE_API_SLUG=api

# Docker/Traefik configuration - ALL REQUIRED
DOMAIN=localhost
TRAEFIK_LOG_LEVEL=INFO

# Monitoring configuration - REQUIRED if using monitoring profile
GRAFANA_PASSWORD=admin123
