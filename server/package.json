{
  "name": "@chat-app/server",
  "type": "module",
  "version": "1.0.0",
  "description": "AI-powered module using vercel AI SDK",
  "keywords": [
    "deepseek",
    "hono",
    "scalar",
    "AI"
  ],
  "module": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "bun test --preload ./src/test/setup-env.ts",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "bun": ">=1.3.11"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@chat-app/shared": "workspace:*",
    "@hono/zod-openapi": "^1.2.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@scalar/hono-api-reference": "^0.10.4",
    "ai": "^6.0.116",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.8",
    "hono-pino": "^0.10.3",
    "langfuse-vercel": "^3.38.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.11",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "postgres": "^3.4.8"
  }
}
