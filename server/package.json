{
  "name": "@chat-app/server",
  "type": "module",
  "version": "1.0.0",
  "description": "AI-powered module using vercel AI SDK",
  "keywords": [
    "deepseek",
    "hono",
    "scalar",
    "AI"
  ],
  "module": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "bun test --preload ./src/test/setup-env.ts",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "dependencies": {
    "@ai-sdk/openai": "4.0.0-beta.28",
    "@ai-sdk/otel": "1.0.0-beta.29",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@chat-app/shared": "workspace:*",
    "@hono/zod-openapi": "^1.2.4",
    "@langfuse/otel": "^5.1.0",
    "@langfuse/tracing": "^5.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@scalar/hono-api-reference": "^0.10.7",
    "ai": "7.0.0-beta.83",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.12",
    "hono-pino": "^0.10.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.12",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "postgres": "^3.4.9"
  }
}
