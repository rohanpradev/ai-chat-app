{
  "name": "@chat-app/server",
  "type": "module",
  "version": "1.0.0",
  "description": "AI-powered module using vercel AI SDK",
  "keywords": [
    "deepseek",
    "hono",
    "scalar",
    "AI"
  ],
  "module": "index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "bun test --preload ./src/test/setup-env.ts"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "@ai-sdk/azure": "^3.0.34",
    "@ai-sdk/openai": "^3.0.33",
    "@asteasolutions/zod-to-openapi": "^8.4.1",
    "@chat-app/shared": "workspace:*",
    "@hono/zod-openapi": "^1.2.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@scalar/hono-api-reference": "^0.9.45",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.2",
    "hono-pino": "^0.10.3",
    "langfuse-vercel": "^3.38.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "stoker": "^2.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.0",
    "bun-types": "^1.3.9",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "postgres": "^3.4.8"
  }
}
