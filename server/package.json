{
  "name": "@chat-app/server",
  "type": "module",
  "version": "1.0.0",
  "description": "AI-powered module using vercel AI SDK",
  "keywords": [
    "deepseek",
    "hono",
    "scalar",
    "AI"
  ],
  "module": "src/index.ts",
  "scripts": {
    "build": "bun build src/index.ts --target=bun --packages=external --outdir dist --root src",
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "bun test --preload ./src/test/setup-env.ts",
    "typecheck": "bun run typecheck:tsgo",
    "typecheck:tsgo": "bunx --no-install --package @typescript/native-preview tsgo --noEmit --project tsconfig.json"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@ai-sdk/openai": "4.0.0-canary.59",
    "@ai-sdk/otel": "1.0.0-canary.88",
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@chat-app/shared": "workspace:*",
    "@hono/zod-openapi": "catalog:",
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@scalar/hono-api-reference": "^0.10.14",
    "@sentry/bun": "^10.53.1",
    "ai": "catalog:",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "catalog:",
    "hono-pino": "^0.10.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "unpdf": "^1.6.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "catalog:",
    "bun-types": "^1.3.14",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "postgres": "^3.4.9"
  }
}
