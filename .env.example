# ============================================
# REQUIRED: Update these 3 values to get started
# ============================================

# OpenAI API Key (Get from platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# JWT Secret (Generate: openssl rand -base64 32)
JWT_SECRET=your_secure_jwt_secret_here_min_32_characters

# Database Password (Change for production)
DB_PASSWORD=postgres

# ============================================
# Optional: Update for production or tools
# ============================================

# Hostname configuration for local TLS and routing
DOMAIN=localhost

# Web Search Tool (Get free API key from serper.dev - optional)
SERPER_API_KEY=

# Langfuse AI Observability (Optional - hosted)
# Create a project in Langfuse Cloud and paste your API keys here, then 'make restart'
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# ============================================
# Defaults: No need to change for local dev
# ============================================

SERVER_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

DB_USER=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=chatapp
DB_URL=postgres://postgres:postgres@db:5432/chatapp

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_AUTH=redis_password
REDIS_URL=redis://:redis_password@redis:6379

CLIENT_URL=http://localhost:5173
BASE_API_SLUG=api

VITE_API_URL=/api
VITE_DEV_MODE=true
VITE_APP_NAME="Chat App"
VITE_APP_VERSION=1.0.0

TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=change-me
DHI_USERNAME=
DHI_PASSWORD=
TRAEFIK_IMAGE=dhi.io/traefik:3.6.11-debian13@sha256:65bd97431b3a35634cd0d0286062c91ed025ab0c8afe28275897652506f80873
POSTGRES_IMAGE=dhi.io/postgres:18.3-debian13
REDIS_IMAGE=dhi.io/redis:8.6.1-debian13

# Kubernetes Gateway options (optional)
# Enable this if you install Traefik and want hostname routing in Kubernetes.
K8S_GATEWAY_ENABLED=false
K8S_APP_HOSTNAME=app.docker.localhost
K8S_TRAEFIK_DASHBOARD_HOSTNAME=traefik.docker.localhost
K8S_TRAEFIK_NAMESPACE=traefik
K8S_TRAEFIK_GATEWAY_NAME=traefik-gateway
TRAEFIK_CHART_REF=oci://dhi.io/traefik-chart
TRAEFIK_CHART_VERSION=37.4.0
TRAEFIK_IMAGE_REGISTRY=dhi.io
TRAEFIK_IMAGE_REPOSITORY=traefik
TRAEFIK_IMAGE_TAG=3.6.11-debian13
TRAEFIK_IMAGE_DIGEST=sha256:65bd97431b3a35634cd0d0286062c91ed025ab0c8afe28275897652506f80873
