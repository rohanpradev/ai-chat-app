apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  labels:
    app.kubernetes.io/name: chat-app
type: Opaque
stringData:
  POSTGRES_PASSWORD: ${DB_PASSWORD:-password}
  DB_PASSWORD: ${DB_PASSWORD:-password}
  JWT_SECRET: ${JWT_SECRET:-your-jwt-secret-here}
  DB_URL: ${DATABASE_URL:-postgres://username:password@db:5432/chatapp}
---
apiVersion: v1
kind: Secret
metadata:
  name: ai-secrets
  labels:
    app.kubernetes.io/name: chat-app
type: Opaque
stringData:
  OPENAI_API_KEY: ${OPENAI_API_KEY:-your-openai-api-key}
  SERPER_API_KEY: ${SERPER_API_KEY:-your-serper-api-key}
