# Client environment variables template
# Copy this file to .env.docker and update values as needed
# All values are REQUIRED unless marked as optional

# Development mode flag - REQUIRED
VITE_DEV_MODE=false

# Application metadata (optional but recommended)
VITE_APP_NAME="Chat App"
VITE_APP_VERSION=1.0.0

# Sentry - OPTIONAL browser error monitoring, tracing, and masked replay
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.1

# Required only during production builds that upload source maps to Sentry.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_RELEASE=
