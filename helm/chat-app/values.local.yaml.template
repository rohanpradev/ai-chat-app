images:
  client:
    tag: latest
    pullPolicy: Never
  server:
    tag: latest
    pullPolicy: Never
  migrate:
    tag: latest
    pullPolicy: Never

config:
  env:
    CLIENT_URL: http://localhost:30080
    DOMAIN: localhost
    NODE_ENV: production
    VITE_DEV_MODE: "false"
    CORS_ORIGINS: http://localhost:5173,http://localhost:30080

secrets:
  app:
    data:
      POSTGRES_PASSWORD: change-me
      DB_PASSWORD: change-me
      REDIS_AUTH: redis_password
      JWT_SECRET: local-dev-jwt-secret-minimum-32-chars-1234567890
      DB_URL: ""
      OPENAI_API_KEY: local-test-openai-key
      SERPER_API_KEY: ""
      LANGFUSE_PUBLIC_KEY: ""
      LANGFUSE_SECRET_KEY: ""
      LANGFUSE_BASEURL: https://cloud.langfuse.com

networkPolicy:
  enabled: false

server:
  replicaCount: 1
  service:
    type: NodePort
    nodePort: 30001
  persistence:
    uploads:
      enabled: false
  hpa:
    enabled: false

client:
  replicaCount: 1
  service:
    type: NodePort
    nodePort: 30080
  hpa:
    enabled: false

exposure:
  gateway:
    enabled: false

migration:
  enabled: false
