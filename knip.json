{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"ignoreExportsUsedInFile": {
		"interface": true,
		"type": true
	},
	"ignoreIssues": {
		"client/src/components/ai-elements/**": [
			"exports",
			"types",
			"nsExports",
			"nsTypes",
			"duplicates",
			"enumMembers",
			"namespaceMembers"
		],
		"client/src/components/ui/**": [
			"exports",
			"types",
			"nsExports",
			"nsTypes",
			"duplicates",
			"enumMembers",
			"namespaceMembers"
		],
		"client/src/utils/query-key.ts": ["exports"],
		"scripts/check-supply-chain.mjs": ["files"],
		"scripts/report-client-bundle-size.mjs": ["files"],
		"server/src/db/schema.ts": ["exports", "types"],
		"server/src/test/setup-env.ts": ["files"]
	},
	"rules": {
		"binaries": "error",
		"catalog": "error",
		"dependencies": "error",
		"devDependencies": "warn",
		"duplicates": "warn",
		"enumMembers": "off",
		"exports": "warn",
		"files": "error",
		"namespaceMembers": "off",
		"nsExports": "warn",
		"nsTypes": "warn",
		"optionalPeerDependencies": "warn",
		"types": "warn",
		"unlisted": "error",
		"unresolved": "error"
	},
	"treatConfigHintsAsErrors": true,
	"workspaces": {
		".": {
			"ignoreBinaries": ["helm", "kubectl", "make"]
		},
		"client": {
			"ignoreBinaries": ["vite!"],
			"ignoreDependencies": [
				"@testing-library/dom",
				"@testing-library/react",
				"@radix-ui/react-hover-card",
				"@radix-ui/react-progress",
				"@radix-ui/react-scroll-area",
				"@rive-app/react-webgl2",
				"@tailwindcss/oxide",
				"@xyflow/react",
				"ansi-to-react",
				"embla-carousel-react",
				"media-chrome",
				"react-jsx-parser",
				"tokenlens",
				"web-vitals"
			],
			"ignoreFiles": [
				"src/components/ai-elements/**",
				"src/components/ui/**",
				"src/reportWebVitals.ts",
				"src/test/setup.ts",
				"src/hooks/useLoadConversation.ts",
				"src/queries/getProfile.ts",
				"src/components/errors/ChatNotFound.tsx",
				"src/components/chat/ChatApp.tsx",
				"src/components/chat/ToolCallDisplay.tsx",
				"src/lib/browser-node-shims/diagnostics-channel.ts"
			]
		},
		"server": {
			"drizzle": {
				"config": []
			},
			"entry": ["drizzle.config.ts"],
			"ignoreDependencies": ["dotenv", "drizzle-zod"],
			"ignoreFiles": ["src/utils/db-utils.ts"]
		},
		"shared": {}
	}
}
